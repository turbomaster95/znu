mainmenu "Configuration"

config CROSS_COMPILE
	string "Cross-compiler tool prefix"
	help
	  Same as running 'make CROSS_COMPILE=prefix-' but stored for
	  default make runs in this kernel build directory.  You don't
	  need to set this unless you want the configured kernel build
	  directory to select the cross-compiler automatically.

source "kernel/Kconfig"


menuconfig GENERATE_ISO
    bool "Generate a Limine iso with the kernel"
    help
      It automatically generates a image.iso file with the Limine bootloader in it.

if GENERATE_ISO

config ISO_MULTI
    bool "Generate a multi-boot iso with both UEFI and BIOS limine."
    select ISO_UEFI
    select ISO_BIOS
    help
      Enabling this creates a single Znu.iso with both UEFI and BIOS limine.

config ISO_BIOS
    bool "Generate Znu.bios.iso"
    help
      This option generates a seperate Znu.bios.iso file with only BIOS limine.

config ISO_UEFI
    bool "Generate Znu.uefi.iso"
    help
      This option generates a seperate Znu.uefi.iso file with only UEFI limine.

endif # GENERATE_ISO

source "uki/Kconfig"

menu "Device Drivers"

source "drivers/Kconfig"

endmenu

config EG_GUI
	bool "Show example gui"
	default n
	select BGA
	help
	  Shows an example gui from kernel mode (DEPRECATED)

