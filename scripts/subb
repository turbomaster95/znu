#!/usr/bin/env python3
import os
import sys
import json
import subprocess
import shutil
import time

MANIFEST = "subb.json"
GITIGNORE = ".gitignore"

HIDE_CURSOR = "\x1b[?25l"
SHOW_CURSOR = "\x1b[?25h"
CLEAR_LINE  = "\x1b[K"

def run(cmd, cwd=None):
    return subprocess.run(cmd, shell=True, cwd=cwd, capture_output=True, text=True)

def manage_gitignore(path, remove=False):
    lines = []
    if os.path.exists(GITIGNORE):
        with open(GITIGNORE, "r") as f:
            lines = [line.strip() for line in f.readlines()]
    
    entry = path.rstrip('/') + '/'
    if remove and entry in lines:
        lines.remove(entry)
    elif not remove and entry not in lines:
        lines.append(entry)
    
    with open(GITIGNORE, "w") as f:
        f.write("\n".join(filter(None, lines)) + "\n")

def get_status_prefix(step, total, action, target):
    prefix = f"[{step}/{total}] {action} "
    cols = shutil.get_terminal_size((80, 20)).columns
    limit = cols - len(prefix) - 5
    
    if len(target) > limit:
        target = "..." + target[-(limit-3):]
        
    return f"{prefix}{target}"

def run_with_dots(cmd, step, total, action, target, cwd=None):
    proc = subprocess.Popen(cmd, shell=True, cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    dots = 0
    sys.stdout.write(HIDE_CURSOR)
    base_text = get_status_prefix(step, total, action, target)
    try:
        while proc.poll() is None:
            dots = (dots + 1) % 4
            ticker = "." * dots + " " * (3 - dots)
            sys.stdout.write(f"\r{base_text} {ticker}{CLEAR_LINE}")
            sys.stdout.flush()
            time.sleep(0.2)
            
        proc.stdout.read()
    finally:
        sys.stdout.write(SHOW_CURSOR)
    return proc.returncode

def run_with_bar(cmd, step, total, action, target, cwd=None, width=15):
    proc = subprocess.Popen(cmd, shell=True, cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    start = time.time()
    sys.stdout.write(HIDE_CURSOR)
    base_text = get_status_prefix(step, total, action, target)
    try:
        while proc.poll() is None:
            elapsed = time.time() - start
            pct = min(95, (elapsed / (elapsed + 4)) * 100)
            filled = int(width * pct / 100)
            bar = "#" * filled + "-" * (width - filled)
            sys.stdout.write(f"\r{base_text} [{bar}]{CLEAR_LINE}")
            sys.stdout.flush()
            time.sleep(0.15)
            
        proc.stdout.read()
    finally:
        sys.stdout.write(SHOW_CURSOR)
    return proc.returncode 

def load_manifest():
    if not os.path.exists(MANIFEST): return {"dependencies": {}}
    with open(MANIFEST, "r") as f: return json.load(f)

def save_manifest(data):
    with open(MANIFEST, "w") as f: json.dump(data, f, indent=4)

def get_default_branch(url):
    res = run(f"git remote show {url}")
    for line in res.stdout.splitlines():
        if "HEAD branch" in line: return line.split(":")[-1].strip()
    return "main"

def add(url, path, branch=None, git_opts=""):
    manifest = load_manifest()
    manage_gitignore(path)
    if branch is None:
        branch = get_default_branch(url)
    
    if not os.path.exists(path):
        cmd = f"git clone {git_opts} -b {branch} {url} {path}".strip()
        run_with_bar(cmd, 1, 1, "Cloning", path)
        sys.stdout.write(f"\r{CLEAR_LINE}done cloned {path}\n")
    else:
        sys.stdout.write(f":D   tracked {path}\n")
    sys.stdout.flush()

    res = run("git rev-parse HEAD", cwd=path)
    current_hash = res.stdout.strip()
    manifest["dependencies"][path] = {"url": url, "branch": branch, "hash": current_hash}
    save_manifest(manifest)

def sync(git_opts=""):
    manifest = load_manifest()
    deps = list(manifest["dependencies"].items())
    total = len(deps)
    
    if total == 0:
        print("Nothing to sync.")
        return

    for i, (path, info) in enumerate(deps, 1):
        manage_gitignore(path)
        dot_git = os.path.join(path, ".git")
        cloned = False
        
        if not os.path.exists(dot_git):
            if os.path.exists(path):
                shutil.rmtree(path)
            cmd = f"git clone {git_opts} -b {info['branch']} {info['url']} {path}".strip()
            run_with_bar(cmd, i, total, "Cloning", path)
            cloned = True

        run_with_dots("git fetch origin", i, total, "Syncing", path, cwd=path)
        
        status_res = run("git status --short", cwd=path).stdout.strip()
        curr_res = run("git rev-parse HEAD", cwd=path).stdout.strip()
        
        run(f"git reset --hard {info['hash']}", cwd=path)
        run("git clean -fd", cwd=path)
        
        if cloned:
            sys.stdout.write(f"\r{CLEAR_LINE}done cloned {path}\n")
        elif status_res or curr_res != info['hash']:
            sys.stdout.write(f"\r{CLEAR_LINE}:D   synced {path}\n")
        else:
            sys.stdout.write(f"\r{CLEAR_LINE}:D   synced {path}\n")
        sys.stdout.flush()

def status():
    manifest = load_manifest()
    if not manifest["dependencies"]:
        print("No dependencies managed by subb.")
        return
    print(f"{'PATH':<30} {'BRANCH':<12} {'HASH':<10} {'STATUS'}")
    print("-" * 70)
    for path, info in manifest["dependencies"].items():
        if not os.path.exists(path):
            stat = "MISSING"
        else:
            res = run("git rev-parse HEAD", cwd=path)
            curr = res.stdout.strip()
            dirty = run("git status --short", cwd=path).stdout.strip()
            stat = "DIRTY" if dirty else ("OK" if curr == info['hash'] else "OUT-OF-SYNC")
        print(f"{path:<30} {info['branch']:<12} {info['hash'][:8]:<10} {stat}")

def update_remote(path, step=1, total=1, git_opts=""):
    manifest = load_manifest()
    if path not in manifest["dependencies"]:
        print(f"Error: {path} not found in manifest.")
        return False

    info = manifest["dependencies"][path]
    cloned = False
    if not os.path.exists(os.path.join(path, ".git")):
        if os.path.exists(path): shutil.rmtree(path)
        cmd = f"git clone {git_opts} -b {info['branch']} {info['url']} {path}".strip()
        run_with_bar(cmd, step, total, "Cloning", path)
        cloned = True

    run_with_dots("git fetch origin", step, total, "Updating", path, cwd=path)
    
    res_before = run("git rev-parse HEAD", cwd=path)
    old_hash = res_before.stdout.strip()
    
    run(f"git reset --hard origin/{info['branch']}", cwd=path)
    
    res_after = run("git rev-parse HEAD", cwd=path)
    new_hash = res_after.stdout.strip()
    
    if cloned:
        sys.stdout.write(f"\r{CLEAR_LINE}:D   cloned {path}\n")
    elif old_hash != new_hash:
        sys.stdout.write(f"\r{CLEAR_LINE}:D   updated {path} ({old_hash[:8]} -> {new_hash[:8]})\n")
    else:
        sys.stdout.write(f"\r{CLEAR_LINE}:D   updated {path}\n")
    sys.stdout.flush()
    
    manifest["dependencies"][path]["hash"] = new_hash
    save_manifest(manifest)
    return True

def remove_dependency(path):
    manifest = load_manifest()
    if path in manifest["dependencies"]:
        manage_gitignore(path, remove=True)
        if os.path.exists(path): shutil.rmtree(path)
        del manifest["dependencies"][path]
        save_manifest(manifest)
        print(f"done removed {path}")
    else:
        print(f"Error: Path '{path}' not found.")

def foreach(shell_cmd):
    manifest = load_manifest()
    for path in manifest["dependencies"]:
        print(f"--- {path} ---")
        subprocess.run(shell_cmd, shell=True, cwd=path)
        print("")

def show_help():
    help_text = """subb - alternative to git submodules which only one person uses

usage:
  subb <command> [arguments]

commands:
  add <url> <path> [branch]   add a new dependency
  sync                        align folders to manifest
  status                      show missing/dirty/out-of-sync
  update <path>               pull latest and update hash
  upgrade                     pull latest for everything
  rm <path>                   remove dep from manifest+disk+gitignore
  foreach "<cmd>"            run command in each dep folder

examples:
  subb add https://github.com/turbomaster95/zline lib/ulibc/third-party/zline trunk
  subb foreach "make clean"
  subb status"""
    print(help_text)

def parse_args(args):
    if "--" in args:
        idx = args.index("--")
        return args[:idx], " ".join(args[idx+1:])
    return args, ""

if __name__ == "__main__":
    raw_args = sys.argv[1:]
    if not raw_args or "help" in raw_args or "-h" in raw_args:
        show_help()
        sys.exit(0)

    args, git_opts = parse_args(raw_args)
    cmd = args[0]

    try:
        if cmd == "add":
            if len(args) < 3:
                print("Error: 'add' requires both a repository URL and a target path.")
                sys.exit(1)
            add(args[1], args[2], args[3] if len(args) > 3 else None, git_opts)
        elif cmd == "sync":
            sync(git_opts)
        elif cmd == "status":
            status()
        elif cmd == "update":
            if len(args) < 2:
                print("Error: 'update' requires a target path. Use 'upgrade' to update everything.")
                sys.exit(1)
            update_remote(args[1], 1, 1, git_opts)
        elif cmd == "upgrade":
            manifest = load_manifest()
            deps = list(manifest["dependencies"].keys())
            total = len(deps)
            for idx, p in enumerate(deps, 1): 
                update_remote(p, idx, total, git_opts)
        elif cmd == "rm":
            if len(args) < 2:
                print("Error: 'rm' requires a target path.")
                sys.exit(1)
            remove_dependency(args[1])
        elif cmd == "foreach":
            if len(args) < 2:
                print("Error: 'foreach' requires a command string.")
                sys.exit(1)
            foreach(" ".join(args[1:]))
        else:
            print(f"Unknown command: {cmd}")
            show_help()
    except KeyboardInterrupt:
        sys.stdout.write(SHOW_CURSOR + "\nInterrupted.\n")
